# Токен бота — получить у @BotFather командой /mybots -> API Token
BOT_TOKEN=123456:ABC-DEF...

# Путь к скачанному JSON-ключу сервисного аккаунта Firebase (см. README.md)
FIREBASE_CREDENTIALS_PATH=./service-account.json

# Имя бакета Firebase Storage — Firebase Console -> Storage (например, как в firebaseConfig сайта)
FIREBASE_STORAGE_BUCKET=guestbook-site-5b1ab.firebasestorage.app

# Необязательно: ссылка на сайт/Mini App, будет присылаться после публикации видео
SITE_URL=https://guestbook-site-5b1ab.web.app
